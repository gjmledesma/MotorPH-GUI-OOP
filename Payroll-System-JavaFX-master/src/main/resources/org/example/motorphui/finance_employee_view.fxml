<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="900.0" stylesheets="@css/employee_view.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.motorphui.ui.HREmployeeView">

   <children>
      <Label fx:id="emp_info_label" layoutX="20.0" layoutY="35.0" text="Employee's Information">
         <font>
            <Font name="Poppins Bold" size="36.0" />
         </font>
      </Label>

      <!--
        TableView placed directly in the AnchorPane — no ScrollPane wrapper.
        TableView already has its own built-in horizontal + vertical scrollbars;
        wrapping it in a ScrollPane creates a second bar.  UNCONSTRAINED_RESIZE_POLICY
        (set in the controller) allows columns to exceed the visible width so the
        built-in bar activates and scrolls all the way to the last column.
      -->
      <TableView fx:id="emp_table" layoutX="17.0" layoutY="102.0" prefHeight="489.0" prefWidth="864.0" AnchorPane.bottomAnchor="99.0" AnchorPane.leftAnchor="17.0" AnchorPane.rightAnchor="19.0" AnchorPane.topAnchor="102.0">
         <columns>
            <TableColumn fx:id="empNumColumn" minWidth="80.0" prefWidth="90.0" text="Employee #" />
            <TableColumn fx:id="lastNameColumn" minWidth="90.0" prefWidth="110.0" text="Last Name" />
            <TableColumn fx:id="firstNameColumn" minWidth="90.0" prefWidth="110.0" text="First Name" />
            <TableColumn fx:id="birthdayColumn" minWidth="80.0" prefWidth="90.0" text="Birthday" />
            <TableColumn fx:id="addressColumn" minWidth="120.0" prefWidth="220.0" text="Address" />
            <TableColumn fx:id="phoneNumberColumn" minWidth="100.0" prefWidth="110.0" text="Phone Number" />
            <TableColumn fx:id="sssColumn" minWidth="100.0" prefWidth="110.0" text="SSS #" />
            <TableColumn fx:id="philHealthColumn" minWidth="110.0" prefWidth="120.0" text="PhilHealth #" />
            <TableColumn fx:id="tinColumn" minWidth="120.0" prefWidth="130.0" text="TIN #" />
            <TableColumn fx:id="pagIbigColumn" minWidth="110.0" prefWidth="120.0" text="Pag-Ibig #" />
            <TableColumn fx:id="statusColumn" minWidth="80.0" prefWidth="90.0" text="Status" />
            <TableColumn fx:id="positionColumn" minWidth="100.0" prefWidth="160.0" text="Position" />
            <TableColumn fx:id="supervisorColumn" minWidth="120.0" prefWidth="160.0" text="Immediate Supervisor" />
            <TableColumn fx:id="basicSalaryColumn" minWidth="90.0" prefWidth="100.0" text="Basic Salary" />
            <TableColumn fx:id="riceSubsidyColumn" minWidth="85.0" prefWidth="95.0" text="Rice Subsidy" />
            <TableColumn fx:id="phoneAllowanceColumn" minWidth="100.0" prefWidth="110.0" text="Phone Allowance" />
            <TableColumn fx:id="clothingAllowanceColumn" minWidth="110.0" prefWidth="120.0" text="Clothing Allowance" />
