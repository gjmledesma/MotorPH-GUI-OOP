<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="900.0" stylesheets="@css/hr_attendance.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.motorphui.ui.HRAttendance">

    <children>

        <!-- Page title -->
        <Label fx:id="attendance_label" layoutX="20.0" layoutY="35.0" text="Attendance">
            <font>
                <Font name="Poppins Bold" size="36.0" />
            </font>
        </Label>

        <!-- ── Filters ─────────────────────────────────────────────────────── -->
        <DatePicker fx:id="data_picker" layoutX="487.0" layoutY="85.0" />
        <TextField fx:id="search_field" layoutX="693.0" layoutY="85.0" prefHeight="25.0" prefWidth="188.0" promptText="Search by Employee # or Name" />

        <!-- ── Attendance TableView ────────────────────────────────────────── -->
        <TableView fx:id="attendance_table" layoutX="20.0" layoutY="133.0" prefHeight="500.0" prefWidth="860.0">
            <columns>

                <!-- fx:id values must match the @FXML field names in HRAttendance.java -->
                <TableColumn fx:id="empNumColumn" prefWidth="100.0" text="Employee #" />

                <TableColumn fx:id="lastNameColumn" prefWidth="123.0" text="Last Name" />

                <TableColumn fx:id="firstNameColumn" prefWidth="143.0" text="First Name" />

                <TableColumn fx:id="dateColumn" prefWidth="115.0" text="Date" />

                <TableColumn fx:id="logInColumn" prefWidth="153.0" text="Login Time" />

                <TableColumn fx:id="logOutColumn" prefWidth="98.0" text="Logout Time" />

                <TableColumn fx:id="statusColumn" prefWidth="128.0" text="Status" />

            </columns>
        </TableView>

    </children>
</AnchorPane>
