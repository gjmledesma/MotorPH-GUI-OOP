<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1200.0" stylesheets="@css/employee_dashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.motorphui.ui.EmployeeDashboard">
   <children>
      <AnchorPane fx:id="contentPane" layoutX="299.0" maxHeight="700.0" maxWidth="900.0" minHeight="700.0" minWidth="900.0" prefHeight="700.0" prefWidth="900.0" stylesheets="@css/employee_dashboard.css" />
      <VBox fx:id="side_menu" alignment="TOP_CENTER" fillWidth="false" prefHeight="700.0" prefWidth="299.0" spacing="20.0" style="-fx-padding: 40 0 20 0;">
         <children>
            <!-- Logo updated to be 1 inch bigger -->
            <ImageView fitHeight="200.0" fitWidth="275.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/MotorPHWhite.png" />
               </image>
               <viewport>
                  <Rectangle2D />
               </viewport>
            </ImageView>
            <Button fx:id="profile_button" alignment="CENTER" mnemonicParsing="false" onAction="#onProfileClicked" prefHeight="45.0" prefWidth="299.0" styleClass="menu-button" text="Profile">
               <font>
                  <Font name="Poppins Regular" size="20.0" />
               </font>
            </Button>
            <Button fx:id="attendance_button" alignment="CENTER" layoutX="10.0" layoutY="144.0" mnemonicParsing="false" onAction="#onAttendanceClicked" prefHeight="45.0" prefWidth="299.0" styleClass="menu-button" text="Attendance">
               <font>
                  <Font name="Poppins Regular" size="20.0" />
               </font>
            </Button>
            <Button fx:id="viewsalary_button" alignment="CENTER" layoutX="10.0" layoutY="144.0" mnemonicParsing="false" onAction="#onViewSalaryClicked" prefHeight="45.0" prefWidth="299.0" styleClass="menu-button" text="View Salary">
               <font>
                  <Font name="Poppins Regular" size="20.0" />
               </font>
            </Button>
            <Button fx:id="leaveform_button" alignment="CENTER" mnemonicParsing="false" onAction="#onLeaveFormClicked" prefHeight="45.0" prefWidth="299.0" styleClass="menu-button" text="Leave Form">
               <font>
                  <Font name="Poppins Regular" size="20.0" />
               </font>
            </Button>
            <Button fx:id="logout_button" alignment="CENTER" mnemonicParsing="false" onAction="#onLogoutClicked" prefHeight="45.0" prefWidth="299.0" styleClass="menu-button" text="Logout">
               <font>
                  <Font name="Poppins Regular" size="20.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</AnchorPane>
