<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="root" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="900.0" stylesheets="@css/employee_view.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.motorphui.ui.HREmployeeView">

   <children>
      <Label fx:id="emp_info_label" layoutX="20.0" layoutY="35.0" text="Employee's Information">
         <font>
            <Font name="Poppins Bold" size="36.0" />
         </font>
      </Label>

      <Button fx:id="viewandupdate_button" layoutX="19.0" layoutY="612.0" onAction="#handleViewAndUpdateButton" prefHeight="36.0" prefWidth="255.0" text="View and Update">
         <font>
            <Font name="Poppins Bold" size="16.0" />
         </font>
      </Button>

      <Button fx:id="addemp_button" layoutX="318.0" layoutY="612.0" onAction="#openAddEmployeeWindow" prefHeight="36.0" prefWidth="255.0" text="Add Employee">
         <font>
            <Font name="Poppins Bold" size="16.0" />
         </font>
      </Button>

      <Button fx:id="deleteemp_button" layoutX="626.0" layoutY="612.0" onAction="#handleDeleteEmployeeButton" prefHeight="36.0" prefWidth="255.0" text="Delete Employee">
         <font>
            <Font name="Poppins Bold" size="16.0" />
         </font>
      </Button>

      <!--
        TableView placed directly in the AnchorPane — no ScrollPane wrapper.
        TableView already has its own built-in horizontal + vertical scrollbars;
        wrapping it in a ScrollPane creates a second bar.  UNCONSTRAINED_RESIZE_POLICY
        (set in the controller) allows columns to exceed the visible width so the
        built-in bar activates and scrolls all the way to the last column.
      -->
      <TableView fx:id="emp_table"
                 layoutX="17.0" layoutY="102.0"
                 prefHeight="489.0" prefWidth="864.0"
                 AnchorPane.leftAnchor="17.0"
                 AnchorPane.rightAnchor="19.0"
                 AnchorPane.topAnchor="102.0"
                 AnchorPane.bottomAnchor="99.0">
         <columns>
            <TableColumn fx:id="empNumColumn"            text="Employee #"             minWidth="80.0"  prefWidth="90.0"/>
            <TableColumn fx:id="lastNameColumn"          text="Last Name"              minWidth="90.0"  prefWidth="110.0"/>
            <TableColumn fx:id="firstNameColumn"         text="First Name"             minWidth="90.0"  prefWidth="110.0"/>
            <TableColumn fx:id="birthdayColumn"          text="Birthday"               minWidth="80.0"  prefWidth="90.0"/>
            <TableColumn fx:id="addressColumn"           text="Address"                minWidth="120.0" prefWidth="220.0"/>
            <TableColumn fx:id="phoneNumberColumn"       text="Phone Number"           minWidth="100.0" prefWidth="110.0"/>
            <TableColumn fx:id="sssColumn"               text="SSS #"                  minWidth="100.0" prefWidth="110.0"/>
            <TableColumn fx:id="philHealthColumn"        text="PhilHealth #"           minWidth="110.0" prefWidth="120.0"/>
            <TableColumn fx:id="tinColumn"               text="TIN #"                  minWidth="120.0" prefWidth="130.0"/>
            <TableColumn fx:id="pagIbigColumn"           text="Pag-Ibig #"             minWidth="110.0" prefWidth="120.0"/>
            <TableColumn fx:id="statusColumn"            text="Status"                 minWidth="80.0"  prefWidth="90.0"/>
            <TableColumn fx:id="positionColumn"          text="Position"               minWidth="100.0" prefWidth="160.0"/>
            <TableColumn fx:id="supervisorColumn"        text="Immediate Supervisor"   minWidth="120.0" prefWidth="160.0"/>
            <TableColumn fx:id="basicSalaryColumn"       text="Basic Salary"           minWidth="90.0"  prefWidth="100.0"/>
            <TableColumn fx:id="riceSubsidyColumn"       text="Rice Subsidy"           minWidth="85.0"  prefWidth="95.0"/>
            <TableColumn fx:id="phoneAllowanceColumn"    text="Phone Allowance"        minWidth="100.0" prefWidth="110.0"/>
            <TableColumn fx:id="clothingAllowanceColumn" text="Clothing Allowance"     minWidth="110.0" prefWidth="120.0"/>
            <TableColumn fx:id="grossSemiMonthlyColumn"  text="Gross Semi-monthly Rate" minWidth="130.0" prefWidth="150.0"/>
            <TableColumn fx:id="hourlyRateColumn"        text="Hourly Rate"            minWidth="85.0"  prefWidth="95.0"/>
         </columns>
      </TableView>
   </children>
</AnchorPane>
